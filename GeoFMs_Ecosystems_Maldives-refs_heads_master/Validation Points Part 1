});

//Sample Points within Water Polygons
var overSampleWaterPoints = ee.FeatureCollection.randomPoints({
  region: waterPolygons.geometry(),
  points: overNumWaterPoints,                                                 //Use previously defined number of points.
  seed: 14                                                                    //Different seed to maintain randomness.
}).map(function(pt){
  return pt.set('class','Water');
});

//Combine Points
var overValidationPoints = overSampleLandPoints.merge(overSampleWaterPoints);             //Merge land and water points.
var overSamplesWithIds = overValidationPoints.map(function(f) {
    var geom = f.geometry();
    return ee.Feature(geom).set({
      date: '',
      sample_id: f.id(),
      grid_id: f.get('grid_id'), 
      latitude: geom.coordinates().get(1),
      longitude: geom.coordinates().get(0),
      method: '',
      int_min: 10, 
      int_max:100,
      iucn_realm: '',
      iucn_biome: '',
      iucn_efg: '',
      efg_10m: '',
      efg2_10m: '',
      efg_100m: '',
      efg2_100m: '',  
      source: '',
      producer: '', 
      int_name: '',
      int_conf: 0,
      rev_name: '',
      rev_conf: 0, 
      samp_type: '',
      year_start: 0,
      year_end: 0,
      hom_10m: 0,
      hom2_10m: 0,
      hom_100m: 0,
      hom2_100m: 0,
      int_com: '',
      rev_com: ''
    })
  });

