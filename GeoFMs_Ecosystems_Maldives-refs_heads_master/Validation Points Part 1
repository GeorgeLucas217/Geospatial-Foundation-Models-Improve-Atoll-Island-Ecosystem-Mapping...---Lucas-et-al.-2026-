////////////////////////////////// STEP 2 - RUN CLASSIFICATION WITH ANNOTATED POINTS ///////////////////////////////////
/////////////////////////// Generate Classified Map with AlphaEarth Foundations Embeddings  //////////////////////////// 
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// 

var filteredPoints = samples.filter(ee.Filter.inList('code_10m',['MT_2_1','T_7_4', 'M_1_1','FM_1_3', 'F_2_2','MFT_1_2','MT_1_1', 
                                                                 'MT_1_3','MT_3_1','M_1_3','M_1_7','M_2_1','TF_1_3','T_7_1']))
                                      .filter(ee.Filter.gte('confidence',4)).filter(ee.Filter.gte('hom_10m',60)); 
var points = filteredPoints.map(function(f) {
  var label = f.get('code_10m');
  var classNumber = ee.Dictionary({'MT_2_1': 0,'T_7_4': 1,'M_1_1': 2,'FM_1_3': 3,'F_2_2': 4,'MFT_1_2': 5,'MT_1_1': 6,'MT_1_3': 7,
                                   'MT_3_1': 8,'M_1_3': 9,'M_1_7': 10,'M_2_1': 11,'TF_1_3': 12,'T_7_1': 13}).get(label);
  return f.set('class_num', classNumber)
});
var paletteIUCN = ['#0DA7E7', '#D68202', '#5E1A9A', '#27F5B5','#786868','#BC3434', '#414383',
                   '#92B636','#1A4ECE', '#6BC181', '#E329E9','#CEA8FE','#850F4F','#C9DB1B'];
var embeddingsG = ee.ImageCollection('GOOGLE/SATELLITE_EMBEDDING/V1/ANNUAL');
var embeddingsG = sites.map(function(f){
  var geomG = f.geometry();
  var imageG = embeddingsG
      .filterDate("2023-01-01", "2025-06-25")
      .filterBounds(geomG)
      .first();
    return ee.Image(imageG).clip(geomG).set('Island_ID', f.get('name'));
});
var clippedImageCollectionG = ee.ImageCollection(embeddingsG);
var mosaicImageG = clippedImageCollectionG.mosaic(); 
var googleBands = ['A00','A01', 'A02', 'A03','A04', 'A05', 'A06','A07', 'A08', 'A09','A10',
                  'A11', 'A12', 'A13','A14', 'A15', 'A16','A17', 'A18', 'A19','A20',
                  'A21', 'A22', 'A23','A24', 'A25', 'A26','A27', 'A28', 'A29','A30',
                  'A31', 'A32', 'A33','A34', 'A35', 'A36','A37', 'A38', 'A39','A40',
                  'A41', 'A42', 'A43','A44', 'A45', 'A46','A47', 'A48', 'A49','A50',
                  'A51', 'A52', 'A53','A54', 'A55', 'A56','A57', 'A58', 'A59','A60',
                  'A61', 'A62', 'A63'];
var trainingG = mosaicImageG.select(googleBands).sampleRegions({
  collection: points,
  properties: ['class_num'],
  scale: 10
});
var classifierG = ee.Classifier.smileRandomForest({
    numberOfTrees: 500,
    seed: 10
  }).train({
    features: trainingG,
    classProperty: 'class_num',
    inputProperties: googleBands                                              //Train the classifier.
});
var classifiedG = mosaicImageG.select(googleBands).classify(classifierG);

//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// 
/////////////////////////////////////////// STEP 3 - LABEL POINTS BY CLASS /////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// 

// Initial Sample

var initLabelledValidationPoints = classifiedG.sampleRegions({
  collection: initSamplesWithIds,
  scale: 10,
  geometries: true
});
print('Labelled Validation Points', initLabelledValidationPoints);

var initClassCounts = initLabelledValidationPoints.aggregate_histogram('classification');
print('Number of Points per Class (Initially Sampled Sample)', initClassCounts);

// Oversampled Sample

var overLabelledValidationPoints = classifiedG.sampleRegions({
