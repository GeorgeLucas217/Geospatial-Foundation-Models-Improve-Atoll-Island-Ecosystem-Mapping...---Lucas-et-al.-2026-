var sites = ee.FeatureCollection("projects/ee-georgelucas217/assets/MaldivesStudySites"),
    samples = ee.FeatureCollection("projects/ee-georgelucas217/assets/samples"),
    S2 = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED");
/***** End of imports. If edited, may not auto-convert in the playground. *****/
