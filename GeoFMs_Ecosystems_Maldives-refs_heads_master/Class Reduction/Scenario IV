  value: "Google Embeddings Classification Scenario IV",
  style: {fontWeight: "bold", fontSize: "16px", margin: "10px 5px"}       //For the map display. This will be relevant later in the code
});


//// Run Classifiers
// Sentinel-2
var training = mosaicImage.select(sentinelBands).sampleRegions({
  collection: trainingPoints,
  properties: ['class_num'],
  scale: 10
});

var classifier = ee.Classifier.smileRandomForest(500).train({             //Random Forest Classifier (Switch as needed with 'ctrl /')
  features: training,
  classProperty: 'class_num',
  inputProperties: sentinelBands                                          //Train the classifier
});

var classified = mosaicImage.select(sentinelBands).classify(classifier);      //Run the classifier

var classified = classified.focal_mode({
  radius: 10,
  kernelType: 'square',
  units: 'meters',
  iterations: 1
});

// Google Satellite Embeddings V1
var trainingG = mosaicImageG.select(googleBands).sampleRegions({
  collection: trainingPoints,
  properties: ['class_num'],
  scale: 10
});

var classifierG = ee.Classifier.smileRandomForest(500).train({            //Random Forest Classifier (Switch as needed with 'ctrl /')
  features: trainingG,
  classProperty: 'class_num',
  inputProperties: googleBands                                              //Train the classifier
});

var classifiedG = mosaicImageG.select(googleBands).classify(classifierG);

//// Accuracy Assessment
// Sentinel-2
var validation = classified.sampleRegions({
  collection: validationPoints,
  properties: ['class_num'],
  scale: 10
});
print(validation)

var confMatrix = validation.errorMatrix("class_num","classification");
var OA = confMatrix.accuracy();
var CA = confMatrix.consumersAccuracy();
var Kappa = confMatrix.kappa();
var PA = confMatrix.producersAccuracy();

print('Confusion Matrix', confMatrix);
print('Overall Accuracy', OA);
print('Consumers Accuracy', CA);
print('Kappa', Kappa);
print('Producers Accuracy', PA);

