                                  'MT_1_1': 3,
                                  'MT_1_3': 3,
                                  'M_1_7': 4,
                                  'M_1_1': 5,
                                  'M_1_3': 6,
                                  'M_2_1': 7}).get(label);
  return f.set('class_num', classNumber)                  //Put the numbers in a new column, named 'class_num'
});

//// Create a pallete from the efg_colours column
