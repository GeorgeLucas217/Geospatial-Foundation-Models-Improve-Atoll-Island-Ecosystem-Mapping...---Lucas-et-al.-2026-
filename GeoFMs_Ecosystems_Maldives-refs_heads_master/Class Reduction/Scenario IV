///////// ---------------------------------------- Load Embeddings -----------------------------------------------

//// ---------- Site map ---------- 
var sites = sites.map(function(f){return f.buffer(10);}); //Loads study site polygons with 10m buffer as was done when points were created

//// ---------- Sentinel-2 Imagery ---------- 
var S2 = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED');             //Import from code for foolproofing

function maskS2clouds(image){
  var qa = image.select('QA60')                                         //Mask clouds function using S2 QA band
  var cloudBitMask = 1<<10;                                             //Clouds are bit 10
  var cirrusBitMask = 1<<11;                                            //Cirrus are bit 11
  var mask = qa.bitwiseAnd(cloudBitMask).eq(0)
    .and(qa.bitwiseAnd(cirrusBitMask).eq(0));                           //set both flats to zero indicating clear conditions.
  return image.updateMask(mask)
    .select("B.*")
    .divide(10000)
    .copyProperties(image,["system:time_start"]);                       //Return masked and scaled data without QA bands.
}

var imageryS2 = sites.map(function(f){
  var geom = f.geometry();                                              //Get the shape of the island.
  var image = S2                                                        //Access Sentinel-2 database.
  .filterDate("2023-01-01", "2025-05-15")                               //Decide which dates to search through.
  .filterBounds(geom)                                                   //Find an image that intersects the island.
  .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 20))                  //Sort images by cloudiness.
  .sort('CLOUDY_PIXEL_PERCENTAGE')
  .map(maskS2clouds)
  .limit(2)                                                             //Limit to the top 2 most cloud free images (for mosaicing in next line).
  .mosaic();                                                            //Account for images intersecting sentinel tile edge.
  return ee.Image(image).clip(geom)                                     //Return the image and clip it by the shape of the island.
  .set('Island_ID', f.get('name'));                                     //Tag images with island names.
});

var clippedImageCollection = ee.ImageCollection(imageryS2);

var mosaicImage = clippedImageCollection.mosaic()                         // Combine images into a mosaic

var ndvi = mosaicImage.normalizedDifference(['B8','B4']).rename('NDVI');
var ndwi = mosaicImage.normalizedDifference(['B3','B8']).rename('NDWI');
mosaicImage = mosaicImage.addBands(ndvi).addBands(ndwi);

var trueColour = {bands: ["B4","B3","B2"], min: 0, max: 0.3, gamma: 1.5};                     //Set true colour for loading into map
var sentinelBands = ['B2','B3','B4','B5','B6','B7','B8','B8A','B11','B12','NDVI','NDWI'];                   //Extract Bands


//// ---------- Google Satellite Embeddings V1 ---------- 
var embeddingsG = ee.ImageCollection('GOOGLE/SATELLITE_EMBEDDING/V1/ANNUAL');                 //Import from code for foolproofing

var embeddingsG = sites.map(function(f){                                                      //Load embeddings to study site geometries
  var geomG = f.geometry();
  var imageG = embeddingsG
      .filterDate("2023-01-01", "2025-06-25")
      .filterBounds(geomG)
      .first();
    return ee.Image(imageG).clip(geomG).set('Island_ID', f.get('name'));
});

var clippedImageCollectionG = ee.ImageCollection(embeddingsG);
var mosaicImageG = clippedImageCollectionG.mosaic();                                          //Combine images into a mosaic to reduce computational load.
var googleBands = ['A00','A01', 'A02', 'A03','A04', 'A05', 'A06','A07', 'A08', 'A09','A10',   //Extract Bands
                  'A11', 'A12', 'A13','A14', 'A15', 'A16','A17', 'A18', 'A19','A20',
                  'A21', 'A22', 'A23','A24', 'A25', 'A26','A27', 'A28', 'A29','A30',
                  'A31', 'A32', 'A33','A34', 'A35', 'A36','A37', 'A38', 'A39','A40',
                  'A41', 'A42', 'A43','A44', 'A45', 'A46','A47', 'A48', 'A49','A50',
                  'A51', 'A52', 'A53','A54', 'A55', 'A56','A57', 'A58', 'A59','A60',
                  'A61', 'A62', 'A63'];

///////// ----------------------------------- Load and Format Points ------------------------------------------

//// Load Annotated Sample Points from Assets (updatable asset from Earth System Studio)
