//// Convert Classes To Numbers
var trainingPoints = filteredTrainingPoints.map(function(f) {
  var label = f.get('code_10m');                          //take labels from 'code_10m' column
  var classNumber = ee.Dictionary({'TF_1_3': 0,           //Give each label a number
                                  'MFT_1_2': 0,
                                  'MT_2_1': 0,
                                  'T_7_1': 1,
                                  'T_7_3': 1,
                                  'T_7_4': 2,
                                  'MT_3_1': 2,
                                  'MT_1_1': 3,
                                  'MT_1_3': 3,
                                  'M_1_7': 4,
                                  'M_1_1': 5,
                                  'M_1_3': 6,
                                  'M_2_1': 7}).get(label);
  return f.set('class_num', classNumber)                  //Put the numbers in a new column, named 'class_num'
});

var validationPoints = filteredValidationPoints.map(function(f) {
  var label = f.get('efg_10m');                          //take labels from 'code_10m' column
  var classNumber = ee.Dictionary({'TF_1_3': 0,           //Give each label a number
                                  'MFT_1_2': 0,
                                  'MT_2_1': 0,
                                  'T_7_1': 1,
                                  'T_7_3': 1,
                                  'T_7_4': 2,
