//// Filter the data
var filteredTrainingPoints = samples.filter(ee.Filter.inList('code_10m',[
  'MT_2_1','T_7_3','T_7_4','M_1_1','MFT_1_2','MT_1_1','MT_1_3','MT_3_1','M_1_3','M_1_7','M_2_1','TF_1_3','T_7_1']))
  .filter(ee.Filter.gte('confidence',4))      //Include only values with confidence 4 or 5
  .filter(ee.Filter.gte('hom_10m',60));       //Include only values with homogeneity over 90%

//// Filter Validation Points
var filteredValidationPoints = validation.filter(ee.Filter.notNull(['efg_10m']))
                                         .filter(ee.Filter.inList('efg_10m',[
   'MT_2_1','T_7_3','T_7_4','M_1_1','MFT_1_2','MT_1_1','MT_1_3','MT_3_1','M_1_3','M_1_7','M_2_1','TF_1_3','T_7_1']))
   .filter(ee.Filter.gte('int_conf',3));      //Include only values with confidence of 3 or greater.


