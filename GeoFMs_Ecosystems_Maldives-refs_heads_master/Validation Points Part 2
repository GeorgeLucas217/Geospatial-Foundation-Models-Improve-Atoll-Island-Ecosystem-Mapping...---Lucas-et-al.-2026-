/**** Start of imports. If edited, may not auto-convert in the playground. ****/
var sites = ee.FeatureCollection("projects/ee-georgelucas217/assets/MaldivesStudySites"),
    samples = ee.FeatureCollection("projects/ee-georgelucas217/assets/samples"),
    initSampledPoints = ee.FeatureCollection("projects/ee-georgelucas217/assets/InitiallySampledPoints"),
    overSampledPoints = ee.FeatureCollection("projects/ee-georgelucas217/assets/OverSampledPoints");
/***** End of imports. If edited, may not auto-convert in the playground. *****/
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// 
////////////////////////////////////////// GENERATING VALIDATION POINTS PART 2 /////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
 
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// 
//////////////////////////////////////// STEP 4 - REDUCE 5000 TO 20 PER CLASS //////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// 

////Assign random number to each point
var pointsWithRandom = overSampledPoints.randomColumn('rand',3);
var sortedPoints = pointsWithRandom.sort('rand');
var numberedPoints = sortedPoints.map(function(feature, index){
  return feature.set('random_id',index);
});
print('Points with random IDs', numberedPoints);

//// Keep 20 or 10%
var classList = overSampledPoints.aggregate_array('classification').distinct(); //Label points per corresponding class
var sampledPerClass = classList.map(function(classValue){
  classValue = ee.Number(classValue);
  var classPoints = overSampledPoints.filter(ee.Filter.eq('classification',classValue));
  var sampled = classPoints.randomColumn('rand',3)
  .sort('rand')
  .limit(20);
  return sampled;
});

var reducedPoints = ee.FeatureCollection(sampledPerClass).flatten();
print('Reduced Points per Class (min 20, or 10%)',reducedPoints);

//// Count number of points in each class
var classCounts = reducedPoints.aggregate_histogram('classification');
print('Number of validation points per class', classCounts)

//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// 
/////////////////////////////////////////////// STEP 5 - COMBINE POINTS ////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// 

// Get unique class values from initial sample
var classValues = initSampledPoints.aggregate_array('classification').distinct();

// Process Each class
var finalPointsPerClass = classValues.map(function(classValue){
  classValue = ee.Number(classValue);
  var initPoints = initSampledPoints.filter(       // Filter init points for this class
    ee.Filter.eq('classification',classValue)
  );
  var initCount = initPoints.size();
  
  var useInit = initCount.gte(20);                            // If number of initial points >= 20, use those
  var selectedInit = initPoints.randomColumn('rand',1).sort('rand');
  
  var fallbackReduced = reducedPoints.filter(                 // Otherwise, use the 20 from the oversampled points.
    ee.Filter.eq('classification',classValue)
  );
  
  return ee.Algorithms.If(useInit, selectedInit, fallbackReduced);
});

var finalValidationPoints = ee.FeatureCollection(finalPointsPerClass).flatten();  //Combine into one feature collection

print('Final Combined Validation Points', finalValidationPoints);







var sites = sites.map(function(f){
  return f.buffer(10);                        //Loads study site polygons with 10m buffer 
}); 
var filteredPoints = samples.filter(ee.Filter.inList('code_10m',['MT_2_1','T_7_4', 'M_1_1','FM_1_3', 'F_2_2','MFT_1_2','MT_1_1', 
                                                                 'MT_1_3','MT_3_1','M_1_3','M_1_7','M_2_1','TF_1_3','T_7_1']))
                                      .filter(ee.Filter.gte('confidence',4)).filter(ee.Filter.gte('hom_10m',60)); 
var points = filteredPoints.map(function(f) {
  var label = f.get('code_10m');
  var classNumber = ee.Dictionary({'MT_2_1': 0,'T_7_4': 1,'M_1_1': 2,'FM_1_3': 3,'F_2_2': 4,'MFT_1_2': 5,'MT_1_1': 6,'MT_1_3': 7,
                                   'MT_3_1': 8,'M_1_3': 9,'M_1_7': 10,'M_2_1': 11,'TF_1_3': 12,'T_7_1': 13}).get(label);
  return f.set('class_num', classNumber)
});
var paletteIUCN = ['#0DA7E7', '#D68202', '#5E1A9A', '#27F5B5','#786868','#BC3434', '#414383',
                   '#92B636','#1A4ECE', '#6BC181', '#E329E9','#CEA8FE','#850F4F','#C9DB1B'];
var embeddingsG = ee.ImageCollection('GOOGLE/SATELLITE_EMBEDDING/V1/ANNUAL');
var embeddingsG = sites.map(function(f){
  var geomG = f.geometry();
  var imageG = embeddingsG
      .filterDate("2023-01-01", "2025-06-25")
      .filterBounds(geomG)
      .first();
    return ee.Image(imageG).clip(geomG).set('Island_ID', f.get('name'));
});
var clippedImageCollectionG = ee.ImageCollection(embeddingsG);
var mosaicImageG = clippedImageCollectionG.mosaic(); 
var googleBands = ['A00','A01', 'A02', 'A03','A04', 'A05', 'A06','A07', 'A08', 'A09','A10',
                  'A11', 'A12', 'A13','A14', 'A15', 'A16','A17', 'A18', 'A19','A20',
                  'A21', 'A22', 'A23','A24', 'A25', 'A26','A27', 'A28', 'A29','A30',
                  'A31', 'A32', 'A33','A34', 'A35', 'A36','A37', 'A38', 'A39','A40',
                  'A41', 'A42', 'A43','A44', 'A45', 'A46','A47', 'A48', 'A49','A50',
                  'A51', 'A52', 'A53','A54', 'A55', 'A56','A57', 'A58', 'A59','A60',
                  'A61', 'A62', 'A63'];
var trainingG = mosaicImageG.select(googleBands).sampleRegions({
  collection: points,
  properties: ['class_num'],
  scale: 10
});
var classifierG = ee.Classifier.smileRandomForest(500).train({            //Random Forest Classifier
  features: trainingG,
  classProperty: 'class_num',
  inputProperties: googleBands                                              //Train the classifier
});
var classifiedG = mosaicImageG.select(googleBands).classify(classifierG);

var finalValidationPointsCount = finalValidationPoints.aggregate_histogram('classification');
print('Final Validation Points Count per Class', finalValidationPointsCount)

var islandCentroids = sites.map(function(feature){
  var centroid = feature.geometry().centroid();
  return ee.Feature(centroid)
    .set('Island_ID', feature.get('name'))
    .set('Atoll_ID', feature.get('Atoll'));
});  

Map.addLayer(islandCentroids, {color: 'yellow'}, 'Island Centroids');
Map.addLayer(classifiedG, {min: 0, max: 13, palette:  
                                                    paletteIUCN},  
                                                    // palettePleasing},
                                                    "Classification with Google Embeddings");
Map.addLayer(reducedPoints,{color:'blue'},'Over Sampled Validation Points After Reduction');
Map.addLayer(finalValidationPoints, {color: 'green'}, 'Final Validation Points')

Export.table.toDrive({
  collection: finalValidationPoints,
  description: 'Validation_Points_To_Be_Labelled',
  folder: 'GEE_Exports_Masters_Research',
  fileFormat: 'SHP'
})






