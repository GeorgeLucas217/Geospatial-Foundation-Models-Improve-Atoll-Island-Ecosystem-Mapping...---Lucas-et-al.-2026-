prob_sentinel<-read.csv("AlphaEarth Paper/probabilities/Class_Probabilities_Sentinel.csv",header=TRUE)
prob_sentinel<-prob_sentinel %>%
  mutate(source="Sentinel") #Add a source column
prob_alphaearth<-read.csv("AlphaEarth Paper/probabilities/Class_Probabilities_Alphaearth.csv",header=TRUE)
prob_alphaearth<-prob_alphaearth %>%
  mutate(source="alphaearth")
head(prob_sentinel)
head(prob_alphaearth)
# Combine the Data
prob_combined<-bind_rows(prob_sentinel,prob_alphaearth)
# Prepare Data
prob_combined$class_number<-as.factor(prob_combined$class_number)
prob_combined$source<-as.factor(prob_combined$source)
head(prob_combined)
# Calculate average of max_probability for every class_number
average_probabilities<-prob_combined%>%
  group_by(class_number,source)%>%
  summarise(
    average_max_probability=mean(max_probability,na.rm=TRUE),
    .groups='drop'
  )
print(average_probabilities)
