# R squared Correlation
# Probability against Accuracy
r2_paga <- combined_data %>%
  group_by(source) %>%
  do(model = lm(average_max_probability ~ accuracypercent, data = .)) %>%
mutate(R_squared = summary(model)$r.squared) %>%
  select(source, R_squared)
print("R-squared: Probability vs. Accuracy")
