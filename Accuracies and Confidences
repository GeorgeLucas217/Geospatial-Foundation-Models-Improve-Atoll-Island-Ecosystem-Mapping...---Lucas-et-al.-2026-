# Order by mean accuracy
classaccuracy <- classaccuracy %>%
  filter(!is.na(efg)) %>%
  mutate(accuracypercent = as.numeric(accuracypercent)) %>%
  group_by(efg) %>%
  mutate(mean_acc = mean(accuracypercent, na.rm = TRUE)) %>%
  ungroup() %>%
  mutate(efg = reorder(efg, -mean_acc))
#Compute average accuracy per efg
avg_accuracy <- classaccuracy %>%
  group_by(efg) %>%
  summarise(avg_acc = mean(accuracypercent, na.rm = TRUE))
